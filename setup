#!/usr/bin/env bash

CURRENT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
EXTRA_SCRIPTS=""

source "$CURRENT_DIR/helpers.sh"

usage() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Sets up your environment with wallpapers, screen saver, and other tools.

Options:
  --extra <files>     Comma-separated list of extra scripts to source.
  -h, --help          Show this help message and exit.

Examples:
  $(basename "$0") --extra ~/scripts/custom1.sh,~/scripts/custom2.sh
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --extra)
                EXTRA_SCRIPTS="$2"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                echo
                usage
                exit 1
                ;;
        esac
    done
}

source_extra_scripts() {
    if [[ -n "$EXTRA_SCRIPTS" ]]; then
        IFS=',' read -ra SCRIPTS <<< "$EXTRA_SCRIPTS"
        for script in "${SCRIPTS[@]}"; do
            if [[ -f "$script" ]]; then
                source "$script"
            else
                echo "Warning: Extra script '$script' not found"
            fi
        done
    fi
}

set_wallpaper_and_screen_saver() {
    local TAG="Setting background and screen saver"

    echo -n "● $TAG"

	osascript -e 'tell application "System Events" to set picture of every desktop to "~/.config/images/Octocat/Octocat big brother background.png"'

	defaults -currentHost write com.apple.screensaver moduleDict -dict moduleName "Classic" path "/System/Library/Screen Savers/Classic.saver" type 0
	defaults -currentHost write com.apple.screensaver photoPath "~/.config/images/Octocat"
	killall cfprefsd

    print_status "$TAG" "$?"
}

main() {
	parse_args "$@"

	install_brew_and_dependencies
	create_symlink ~/.config/git/gitconfig.ini ~/.gitconfig
	create_symlink ~/.config/zsh/zshrc ~/.zshrc
	set_wallpaper_and_screen_saver

	source_extra_scripts
}

main $@
