#!/usr/bin/env bash

CURRENT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

source "$CURRENT_DIR/helpers.sh"


main() {
	install_brew_and_dependencies Brewfile.kraken
	install_or_update_uv_tool git+ssh://git@github.com/octoenergy/ktdb.git ktdb
	install_or_update_uv_tool git+https://github.com/octoenergy/ktl-data-cli
}
 
main
